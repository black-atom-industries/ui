{
    "$schema": "https://raw.githubusercontent.com/denoland/deno/main/cli/schemas/config-file.v1.json",
    "name": "@black-atom/ui",
    "version": "0.0.1",
    "exports": {
        ".": "./src/mod.ts"
    },
    "tasks": {
        "check": "deno check src/",
        "lint": "deno lint",
        "fmt": "deno fmt",
        "test": "deno test --allow-all",
        "checks": "deno task check && deno task lint && deno task fmt && deno task test",
        "publish": "deno publish --allow-slow-types"
    },
    "lint": {
        "rules": {
            "exclude": ["no-slow-types"]
        }
    },
    "fmt": {
        "useTabs": false,
        "lineWidth": 100,
        "indentWidth": 4,
        "semiColons": true,
        "singleQuote": false,
        "proseWrap": "preserve"
    },
    "imports": {
        "@black-atom/core": "jsr:@black-atom/core"
    }
}
